<Window x:Class="MyWPFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyWPFApp"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="450"
        Width="800"
        Loaded="Window_Loaded">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170*"/>
            <ColumnDefinition Width="631*"/>
        </Grid.ColumnDefinitions>

        <ComboBox x:Name="LeftSet"
                  HorizontalAlignment="Left"
                  Margin="10,32,0,0"
                  VerticalAlignment="Top"
                  Width="173"
                  Height="32"
                  SelectionChanged="LeftMySet_SelectionChanged"/>

        <ComboBox x:Name="Operation"
                  HorizontalAlignment="Left"
                  Margin="57,32,0,0"
                  VerticalAlignment="Top"
                  Width="173"
                  Height="32"
                  Grid.Column="1"/>

        <ComboBox x:Name="RightSet"
                  HorizontalAlignment="Left"
                  Margin="256,32,0,0"
                  VerticalAlignment="Top"
                  Width="173"
                  Height="32"
                  Grid.Column="1"
                  SelectionChanged="RightMySet_SelectionChanged"/>

        <Button x:Name="evaluateButton"
                Content="Evaluate"
                HorizontalAlignment="Left"
                Margin="448,32,0,0"
                VerticalAlignment="Top"
                Width="173"
                Height="32"
                Grid.Column="1"
                Click="evaluateButton_Click"/>

        <ListBox x:Name="LeftMember"
                 HorizontalAlignment="Left"
                 Height="346"
                 Margin="10,88,0,0"
                 VerticalAlignment="Top"
                 Width="173"
                 SelectionChanged="ListBox_SelectionChanged"/>

        <ListBox x:Name="RightMember"
                 HorizontalAlignment="Left"
                 Height="346"
                 Margin="256,88,0,0"
                 VerticalAlignment="Top"
                 Width="173"
                 Grid.Column="1"/>

        <ListBox x:Name="ResultSet"
                 HorizontalAlignment="Left"
                 Height="346"
                 Margin="452,88,0,0"
                 VerticalAlignment="Top"
                 Width="168"
                 Grid.Column="1"/>

    </Grid>
</Window>